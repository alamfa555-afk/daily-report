rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check if the user is an approved operator for a specific site ID
    function isApprovedOperatorForSite(siteId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved' &&
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'operator' &&
            siteId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.assignedSiteIds
          )
        );
    }

    // Helper function to check if the user is an approved operator (general)
    function isApprovedOperator() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved';
    }

    // users collection:
    // - Anyone authenticated can read their own profile or write to create their own initial profile (when status is pending)
    // - Admins can read and write all profiles
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId && 
        request.resource.data.role == 'operator' && 
        request.resource.data.status == 'pending';
      allow update, delete: if isAdmin() || (request.auth != null && request.auth.uid == userId && request.resource.data.role == resource.data.role && request.resource.data.status == resource.data.status && request.resource.data.assignedSiteIds == resource.data.assignedSiteIds);
    }

    // sites collection:
    // - Anyone (including unauthenticated viewers) can read sites
    // - Only admins can write (create, update, delete) sites
    match /sites/{siteId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // deliveries collection:
    // - Anyone can read deliveries
    // - Approved operators for that site, or admins, can write (create, update, delete) deliveries
    match /deliveries/{deliveryId} {
      allow read: if true;
      allow create: if isAdmin() || isApprovedOperatorForSite(request.resource.data.siteId);
      allow update: if isAdmin() || (isApprovedOperatorForSite(resource.data.siteId) && isApprovedOperatorForSite(request.resource.data.siteId));
      allow delete: if isAdmin() || isApprovedOperatorForSite(resource.data.siteId);
    }

    // erections collection:
    // - Anyone can read erections
    // - Approved operators for that site, or admins, can write (create, update, delete) erections
    match /erections/{erectionId} {
      allow read: if true;
      allow create: if isAdmin() || isApprovedOperatorForSite(request.resource.data.siteId);
      allow update: if isAdmin() || (isApprovedOperatorForSite(resource.data.siteId) && isApprovedOperatorForSite(request.resource.data.siteId));
      allow delete: if isAdmin() || isApprovedOperatorForSite(resource.data.siteId);
    }

    // suggestions collection:
    // - Anyone can read suggestions
    // - Any approved operator or admin can write suggestions
    match /suggestions/{suggestionId} {
      allow read: if true;
      allow write: if isApprovedOperator() || isAdmin();
    }

    // equipment collection:
    // - Anyone can read equipment
    // - Approved operators for that site, or admins, can write equipment
    match /equipment/{equipmentId} {
      allow read: if true;
      allow create: if isAdmin() || isApprovedOperatorForSite(request.resource.data.siteId);
      allow update: if isAdmin() || (isApprovedOperatorForSite(resource.data.siteId) && isApprovedOperatorForSite(request.resource.data.siteId));
      allow delete: if isAdmin() || isApprovedOperatorForSite(resource.data.siteId);
    }
  }
}
